  // <leader>sS = goto symbol (workspace)
  {
    "key": "space s shift+s",
    "command": "workbench.action.showAllSymbols",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>sg = grep (root dir) — was wrongly SCM before
  {
    "key": "space s g",
    "command": "workbench.action.findInFiles",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>sG = grep (cwd)
  {
    "key": "space s shift+g",
