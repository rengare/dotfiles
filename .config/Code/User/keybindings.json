[
  // ── Terminal ─────────────────────────────────────────────────────────────
  {
    "key": "ctrl+/",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus",
  },
  {
    "key": "ctrl+/",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus",
  },
  // toggle when outside terminal, split when inside
  {
    "key": "ctrl+\\",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "!terminalFocus",
  },
  {
    "key": "ctrl+\\",
    "command": "workbench.action.terminal.split",
    "when": "terminalFocus",
  },
  // new terminal / kill terminal
  {
    "key": "ctrl+n",
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus",
  },
  {
    "key": "ctrl+q",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus",
  },
  // navigate split panes left/right (same as editor C-h/l)
  {
    "key": "ctrl+h",
    "command": "workbench.action.terminal.focusPreviousPane",
    "when": "terminalFocus",
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus",
  },
  // cycle between multiple terminals with alt+h/l
  {
    "key": "alt+h",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus",
  },
  {
    "key": "alt+l",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus",
  },

  // ── vim ctrl+p passthrough ────────────────────────────────────────────────
  {
    "key": "shift+alt+p",
    "command": "extension.vim_ctrl+p",
    "when": "editorTextFocus && vim.active && vim.use<C-p> && !inDebugRepl || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'CommandlineInProgress' || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'SearchInProgressMode'",
  },
  {
    "key": "ctrl+p",
    "command": "-extension.vim_ctrl+p",
    "when": "editorTextFocus && vim.active && vim.use<C-p> && !inDebugRepl || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'CommandlineInProgress' || vim.active && vim.use<C-p> && !inDebugRepl && vim.mode == 'SearchInProgressMode'",
  },

  // ── Window navigation (C-hjkl) ────────────────────────────────────────────
  {
    "key": "ctrl+h",
    "command": "workbench.action.focusLeftGroup",
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.focusBelowGroup",
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.focusAboveGroup",
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusRightGroup",
  },

  // ── Undo/Redo (use VSCode's undo so file-modified state stays in sync) ────
  {
    "key": "u",
    "command": "undo",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "ctrl+r",
    "command": "redo",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Save ──────────────────────────────────────────────────────────────────
  {
    "key": "ctrl+s",
    "command": "workbench.action.files.save",
  },
  {
    "key": "ctrl+shift+s",
    "command": "workbench.action.files.saveAll",
  },

  // ── Select all ───────────────────────────────────────────────────────────
  {
    "key": "ctrl+a",
    "command": "editor.action.selectAll",
    "when": "editorTextFocus",
  },

  // ── Buffer nav (C-S-h/l) ─────────────────────────────────────────────────
  {
    "key": "ctrl+shift+h",
    "command": "workbench.action.previousEditorInGroup",
  },
  {
    "key": "ctrl+shift+l",
    "command": "workbench.action.nextEditorInGroup",
  },

  // ── Close ─────────────────────────────────────────────────────────────────
  {
    "key": "shift+q",
    "command": "workbench.action.closeActiveEditor",
    "when": "editorTextFocus && vim.active && vim.mode == 'Normal'",
  },
  {
    "key": "ctrl+q",
    "command": "workbench.action.closeActiveEditor",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+w",
    "command": "workbench.action.closeActiveEditor",
  },
  {
    "key": "ctrl+shift+t",
    "command": "workbench.action.reopenClosedEditor",
  },

  // ── Move lines (A-j/k) ───────────────────────────────────────────────────
  {
    "key": "alt+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "alt+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "shift+alt+j",
    "command": "editor.action.copyLinesDownAction",
    "when": "editorTextFocus && !editorReadonly",
  },
  {
    "key": "shift+alt+k",
    "command": "editor.action.copyLinesUpAction",
    "when": "editorTextFocus && !editorReadonly",
  },

  // ── Explorer / SCM / Search sidebar ──────────────────────────────────────
  {
    "key": "ctrl+shift+e",
    "command": "workbench.view.explorer",
  },
  {
    "key": "ctrl+e",
    "command": "workbench.action.focusSideBar",
    "when": "!sideBarFocus",
  },
  {
    "key": "ctrl+e",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "sideBarFocus",
  },
  {
    "key": "ctrl+shift+f",
    "command": "workbench.action.findInFiles",
  },
  {
    "key": "ctrl+shift+g",
    "command": "workbench.view.scm",
  },

  // ── Rename / quickfix / markers ───────────────────────────────────────────
  {
    "key": "f2",
    "command": "editor.action.rename",
    "when": "editorHasRenameProvider && editorTextFocus && !editorReadonly",
  },
  {
    "key": "alt+enter",
    "command": "editor.action.quickFix",
    "when": "editorTextFocus",
  },
  {
    "key": "f8",
    "command": "editor.action.marker.next",
    "when": "editorTextFocus",
  },
  {
    "key": "shift+f8",
    "command": "editor.action.marker.prev",
    "when": "editorTextFocus",
  },

  // ── Top-level: <leader><space>  <leader>:  <leader>? ─────────────────────
  {
    "key": "space space",
    "command": "workbench.action.quickOpen",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space shift+;",
    "command": "workbench.action.showCommands",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space shift+/",
    "command": "workbench.action.openGlobalKeybindings",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space e",
    "command": "workbench.view.explorer",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>/ = live grep (root dir)
  {
    "key": "space /",
    "command": "workbench.action.findInFiles",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>, = switch buffer
  {
    "key": "space ,",
    "command": "workbench.action.showAllEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Files (f) ─────────────────────────────────────────────────────────────
  // <leader>ff = find files (root dir)
  {
    "key": "space f f",
    "command": "workbench.action.quickOpen",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fF = find files (cwd)
  {
    "key": "space f shift+f",
    "command": "workbench.action.quickOpen",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fb = buffers
  {
    "key": "space f b",
    "command": "workbench.action.showAllEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fB = all buffers
  {
    "key": "space f shift+b",
    "command": "workbench.action.showAllEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fg = git files
  {
    "key": "space f g",
    "command": "workbench.action.quickOpen",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fr = recent files
  {
    "key": "space f r",
    "command": "workbench.action.openRecent",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fR = recent (cwd)
  {
    "key": "space f shift+r",
    "command": "workbench.action.openRecent",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fw = find word in file
  {
    "key": "space f w",
    "command": "actions.find",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>fn = new file
  {
    "key": "space f n",
    "command": "workbench.action.files.newUntitledFile",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>ft = terminal (root dir)
  {
    "key": "space f t",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Buffers (b) ───────────────────────────────────────────────────────────
  {
    "key": "space b d",
    "command": "workbench.action.closeActiveEditor",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bD = delete buffer and window
  {
    "key": "space b shift+d",
    "command": "workbench.action.closeActiveEditor",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bj = pick buffer
  {
    "key": "space b j",
    "command": "workbench.action.showAllEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bl = delete buffers to the left
  {
    "key": "space b l",
    "command": "workbench.action.closeEditorsToTheLeft",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>br = delete buffers to the right
  {
    "key": "space b r",
    "command": "workbench.action.closeEditorsToTheRight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bo = delete other buffers
  {
    "key": "space b o",
    "command": "workbench.action.closeOtherEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bp = toggle pin
  {
    "key": "space b p",
    "command": "workbench.action.pinEditor",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bP = delete non-pinned buffers
  {
    "key": "space b shift+p",
    "command": "workbench.action.closeUnpinnedEditors",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>bb = switch to other buffer
  {
    "key": "space b b",
    "command": "workbench.action.openPreviousRecentlyUsedEditorInGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "] b",
    "command": "workbench.action.nextEditorInGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "[ b",
    "command": "workbench.action.previousEditorInGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Windows (w) ───────────────────────────────────────────────────────────
  // navigate
  {
    "key": "space w h",
    "command": "workbench.action.focusLeftGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w j",
    "command": "workbench.action.focusBelowGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w k",
    "command": "workbench.action.focusAboveGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w l",
    "command": "workbench.action.focusRightGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w w",
    "command": "workbench.action.focusNextGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // move window to far edge
  {
    "key": "space w shift+h",
    "command": "workbench.action.moveActiveEditorGroupLeft",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+j",
    "command": "workbench.action.moveActiveEditorGroupDown",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+k",
    "command": "workbench.action.moveActiveEditorGroupUp",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+l",
    "command": "workbench.action.moveActiveEditorGroupRight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // split
  {
    "key": "space w v",
    "command": "workbench.action.splitEditorRight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w s",
    "command": "workbench.action.splitEditorDown",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // close
  {
    "key": "space w d",
    "command": "workbench.action.closeActiveEditorGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w q",
    "command": "workbench.action.closeActiveEditorGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w o",
    "command": "workbench.action.closeOtherEditorGroups",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // swap / break out
  {
    "key": "space w x",
    "command": "workbench.action.moveEditorToNextGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+t",
    "command": "workbench.action.moveEditorToNewWindow",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // zoom / maximize
  {
    "key": "space w m",
    "command": "workbench.action.maximizeEditorHideSidebar",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+-",
    "command": "workbench.action.maximizeEditorHideSidebar",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+\\",
    "command": "workbench.action.maximizeEditorHideSidebar",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // resize
  {
    "key": "space w shift+=",
    "command": "workbench.action.increaseViewHeight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w -",
    "command": "workbench.action.decreaseViewHeight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+,",
    "command": "workbench.action.decreaseViewWidth",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w shift+.",
    "command": "workbench.action.increaseViewWidth",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space w =",
    "command": "workbench.action.evenEditorWidths",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>- = split below
  {
    "key": "space -",
    "command": "workbench.action.splitEditorDown",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>| = split right
  {
    "key": "space shift+\\",
    "command": "workbench.action.splitEditorRight",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // window resize
  {
    "key": "ctrl+up",
    "command": "workbench.action.increaseViewHeight",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+down",
    "command": "workbench.action.decreaseViewHeight",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+left",
    "command": "workbench.action.decreaseViewWidth",
    "when": "editorTextFocus",
  },
  {
    "key": "ctrl+right",
    "command": "workbench.action.increaseViewWidth",
    "when": "editorTextFocus",
  },

  // ── Code / LSP (c) ────────────────────────────────────────────────────────
  {
    "key": "space c a",
    "command": "editor.action.quickFix",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space c r",
    "command": "editor.action.rename",
    "when": "vim.mode == 'Normal' && editorTextFocus && editorHasRenameProvider && !editorReadonly",
  },
  {
    "key": "space c f",
    "command": "editor.action.formatDocument",
    "when": "vim.mode == 'Normal' && editorTextFocus && !editorReadonly",
  },
  // <leader>cd = line diagnostics
  {
    "key": "space c d",
    "command": "editor.action.showHover",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>cs = symbols (aerial/trouble)
  {
    "key": "space c s",
    "command": "workbench.action.gotoSymbol",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>cS = LSP references/definitions (trouble lsp)
  {
    "key": "space c shift+s",
    "command": "editor.action.goToReferences",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // gg = go to top of file
  {
    "key": "g g",
    "command": "cursorTop",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // gcc = comment line, gc = comment selection
  {
    "key": "g c c",
    "command": "editor.action.commentLine",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g c",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && (vim.mode == 'Visual' || vim.mode == 'VisualLine' || vim.mode == 'VisualBlock')",
  },
  // text-object-like sequences moved to VSCodeVim settings so plain v still
  // enters visual mode instead of being swallowed by VS Code chord handling

  // H/M/L = viewport top/middle/bottom
  {
    "key": "shift+h",
    "command": "cursorMove",
    "args": { "to": "viewPortTop" },
    "when": "vim.mode == 'Normal' && editorTextFocus && !notebookEditorFocused",
  },
  {
    "key": "shift+m",
    "command": "cursorMove",
    "args": { "to": "viewPortCenter" },
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "shift+l",
    "command": "cursorMove",
    "args": { "to": "viewPortBottom" },
    "when": "vim.mode == 'Normal' && editorTextFocus && !notebookEditorFocused",
  },
  // gd/gD/gr/gi/gI/gy
  {
    "key": "g d",
    "command": "editor.action.revealDefinition",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g shift+d",
    "command": "editor.action.revealDeclaration",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g r",
    "command": "editor.action.goToReferences",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g i",
    "command": "editor.action.goToImplementation",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g shift+i",
    "command": "editor.action.goToImplementation",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g y",
    "command": "editor.action.goToTypeDefinition",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // gO = document symbols
  {
    "key": "g shift+o",
    "command": "workbench.action.gotoSymbol",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // gw = format
  {
    "key": "g w",
    "command": "editor.action.formatDocument",
    "when": "vim.mode == 'Normal' && editorTextFocus && !editorReadonly",
  },
  // gt/gT = next/prev tab
  {
    "key": "g t",
    "command": "workbench.action.nextEditorInGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "g shift+t",
    "command": "workbench.action.previousEditorInGroup",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // K = hover
  {
    "key": "shift+k",
    "command": "editor.action.showHover",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Git (g) ───────────────────────────────────────────────────────────────
  // <leader>gg = lazygit (root dir) → SCM panel
  {
    "key": "space g g",
    "command": "workbench.view.scm",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gG = lazygit (cwd)
  {
    "key": "space g shift+g",
    "command": "workbench.view.scm",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gs = git status
  {
    "key": "space g s",
    "command": "workbench.view.scm",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gc = git commits
  {
    "key": "space g c",
    "command": "git.viewHistory",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gl = git log
  {
    "key": "space g l",
    "command": "git.viewHistory",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gL = git log (cwd)
  {
    "key": "space g shift+l",
    "command": "git.viewHistory",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gd = git diff (files)
  {
    "key": "space g d",
    "command": "git.openChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gf = git current file history
  {
    "key": "space g f",
    "command": "git.openChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gb = git blame line
  {
    "key": "space g b",
    "command": "git.blame",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>gB = git browse (open on remote)
  {
    "key": "space g shift+b",
    "command": "workbench.view.scm",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>go = toggle mini.diff overlay
  {
    "key": "space g o",
    "command": "git.openChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // hunk navigation: ]h/[h next/prev, ]H/[H last/first
  {
    "key": "] h",
    "command": "workbench.action.editor.nextChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "[ h",
    "command": "workbench.action.editor.previousChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "] shift+h",
    "command": "workbench.action.editor.nextChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "[ shift+h",
    "command": "workbench.action.editor.previousChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // hunk ops: <leader>gh* (stage/reset/preview/diff/blame)
  {
    "key": "space g h s",
    "command": "git.stageSelectedRanges",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  {
    "key": "space g h r",
    "command": "git.revertSelectedRanges",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>ghS = stage buffer
  {
    "key": "space g h shift+s",
    "command": "git.stageFile",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>ghp = preview hunk inline
  {
    "key": "space g h p",
    "command": "editor.action.dirtydiff.next",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>ghd = diff this
  {
    "key": "space g h d",
    "command": "git.openChange",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },
  // <leader>ghb = blame line
  {
    "key": "space g h b",
    "command": "git.blame",
    "when": "vim.mode == 'Normal' && editorTextFocus",
  },

  // ── Search (s) ────────────────────────────────────────────────────────────
