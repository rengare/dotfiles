#!/bin/bash

bat=$(grep -rl '^Battery$' /sys/class/power_supply/*/type 2>/dev/null | head -1 | xargs dirname)

if [ -z "$bat" ]; then
    exit 0
fi

if [ -f "$bat/capacity" ]; then
    cap=$(cat "$bat/capacity")
else
    now=$(cat "$bat/energy_now")
    full=$(cat "$bat/energy_full")
    cap=$(( now * 100 / full ))
fi

status=$(cat "$bat/status" 2>/dev/null)

case "$status" in
    Charging)     suffix=" ↑" ;;
    Discharging)  suffix=" ↓" ;;
    "Not charging") suffix=" =" ;;
    Full)         suffix=" =" ;;
    *)            suffix="" ;;
esac

if [ "$status" = "Discharging" ] && [ "$cap" -le 10 ]; then
    notify-send -u critical "Battery Low" "${cap}% remaining"
fi

echo "bat ${cap}%${suffix}"
