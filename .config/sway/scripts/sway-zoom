#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-}"

need() { command -v "$1" >/dev/null 2>&1 || { echo "Missing: $1" >&2; exit 127; }; }
need swaymsg
need jq
need awk

STEPS_STR="${SWAY_ZOOM_STEPS:-"1.0 1.25 1.5 1.75 2.0"}"
read -r -a STEPS <<<"$STEPS_STR"

is_number() { [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]; }

outputs_json="$(swaymsg -t get_outputs)"

# Use SWAY_OUTPUT if set, else the currently focused output
output_name="${SWAY_OUTPUT:-$(jq -r '.[] | select(.focused == true) | .name' <<<"$outputs_json")}"

if [[ -z "${output_name}" || "${output_name}" == "null" ]]; then
  echo "Could not determine output name (try: SWAY_OUTPUT=eDP-1 $0 in)" >&2
  exit 1
fi

current_scale="$(jq -r --arg name "$output_name" '.[] | select(.name == $name) | .scale' <<<"$outputs_json")"
if [[ -z "${current_scale}" || "${current_scale}" == "null" ]]; then
  echo "Could not read current scale for output '$output_name'." >&2
  exit 1
fi

closest_i=0
closest_diff="999999"

for i in "${!STEPS[@]}"; do
  s="${STEPS[$i]}"
  diff="$(awk -v a="$current_scale" -v b="$s" 'BEGIN{d=a-b; if(d<0)d=-d; print d}')"
  better="$(awk -v d="$diff" -v best="$closest_diff" 'BEGIN{print (d+0 < best+0) ? 1 : 0}')"
  if [[ "$better" == "1" ]]; then
    closest_diff="$diff"
    closest_i="$i"
  fi
done

apply_scale() {
  local new_scale="$1"
  swaymsg output "$output_name" scale "$new_scale" >/dev/null
  echo "$output_name scale: $current_scale -> $new_scale"
}

case "$cmd" in
  in)
    ni=$((closest_i + 1))
    (( ni >= ${#STEPS[@]} )) && ni=$(( ${#STEPS[@]} - 1 ))
    apply_scale "${STEPS[$ni]}"
    ;;
  out)
    ni=$((closest_i - 1))
    (( ni < 0 )) && ni=0
    apply_scale "${STEPS[$ni]}"
    ;;
  *)
    echo "Usage: $0 {in|out}" >&2
    echo "Output:  $output_name" >&2
    echo "Current: $current_scale" >&2
    echo "Steps:   $STEPS_STR" >&2
    exit 2
    ;;
esac
