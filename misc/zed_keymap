[
  // ========= Workspace =========
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-/": "workspace::ToggleBottomDock",
      "ctrl-\\": "terminal_panel::ToggleFocus",
      "cmd-b": "workspace::ToggleRightDock",
      "cmd-k": "workspace::ToggleRightDock",
    },
  },

  // ========= Cross-surface pane navigation =========
  {
    "context": "Dock || Terminal || Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },

  // ========= Panels =========
  {
    "context": "GitPanel",
    "bindings": {
      "q": "git_panel::Close",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-\\": "workspace::ToggleRightDock",
      "cmd-k": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "RightDock",
    "bindings": {
      "space b": "workspace::ToggleRightDock",
    },
  },

  // ========= Project panel (netrw-ish) =========
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "q": "workspace::ToggleLeftDock",
      "space e": "workspace::ToggleLeftDock",
      ":": "command_palette::Toggle",
      "%": "project_panel::NewFile",
      "/": "project_panel::NewSearchInDirectory",
      "enter": "project_panel::OpenPermanent",
      "escape": "project_panel::ToggleFocus",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::ExpandSelectedEntry",
      "o": "project_panel::OpenPermanent",
      "shift-d": "project_panel::Delete",
      "shift-r": "project_panel::Rename",
      "t": "project_panel::OpenPermanent",
      "v": "project_panel::OpenPermanent",
      "shift-g": "menu::SelectLast",
      "g g": "menu::SelectFirst",
      "-": "project_panel::SelectParent",
      "ctrl-6": "pane::AlternateFile",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },

  // ========= Empty pane =========
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space f f": "file_finder::Toggle",
      "space f p": "projects::OpenRecent",
      "space p p": "projects::OpenRecent",
      "space f n": "workspace::NewFile",
      "space s g": "workspace::NewSearch",
      "space q q": "zed::Quit",
    },
  },

  // ========= Editor (normal + visual, general motions) =========
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "space g h d": "editor::ToggleSelectedDiffHunks",
      "space g s": "git_panel::ToggleFocus",
      "space u h": "editor::ToggleInlayHints",
      "space u w": "editor::ToggleSoftWrap",
      "space u z": "workspace::ToggleCenteredLayout",
      "space m p": "markdown::OpenPreview",
      "space m shift-p": "markdown::OpenPreviewToTheSide",
      "space f p": "projects::OpenRecent",
      "space p p": "projects::OpenRecent",
      "space a c": "agent::ToggleFocus",
      "space a g": "agent::ToggleFocus",
      "space a i": "assistant::InlineAssist",
      "space a t": "assistant::InlineAssist",
      "g f": "editor::OpenExcerpts",
    },
  },

  // ========= Editor (VimControl — all leader bindings) =========
  {
    "context": "Editor && VimControl && !VimWaiting && !menu",
    "bindings": {
      // ── Top-level ──
      "space space": "file_finder::Toggle",
      "space shift-;": "command_palette::Toggle",
      "space /": "pane::DeploySearch",
      "space ,": "tab_switcher::Toggle",
      "space e": "workspace::ToggleLeftDock",

      // ── Files (f) ──
      "space f f": "file_finder::Toggle",
      "space f shift-f": "file_finder::Toggle",
      "space f b": "tab_switcher::Toggle",
      "space f r": "workspace::OpenRecent",
      "space f n": "workspace::NewFile",

      // ── Buffers (b) ──
      "space b b": "pane::AlternateFile",
      "space b d": "pane::CloseActiveItem",
      "space b shift-d": "pane::CloseActiveItem",
      "space b j": "tab_switcher::Toggle",
      "space b l": "pane::CloseItemsToTheLeft",
      "space b r": "pane::CloseItemsToTheRight",
      "space b o": "pane::CloseOtherItems",
      "space b p": "pane::TogglePinTab",
      "space b shift-p": "pane::CloseUnpinnedItems",
      "] b": "pane::ActivateNextItem",
      "[ b": "pane::ActivatePreviousItem",

      // ── Windows (w) ──
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      "space w l": "workspace::ActivatePaneRight",
      "space w w": "workspace::ActivateNextPane",
      "space w v": "pane::SplitRight",
      "space w s": "pane::SplitDown",
      "space w d": "pane::CloseAllItems",
      "space w q": "pane::CloseAllItems",
      "space w o": "workspace::CloseInactiveTabsAndPanes",
      "space w m": "workspace::ToggleCenteredLayout",
      "space w shift-z": "workspace::ToggleCenteredLayout",
      "space -": "pane::SplitDown",
      "space shift-\\": "pane::SplitRight",

      // ── Code / LSP (c) ──
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c f": "editor::Format",
      "space c d": "editor::Hover",
      "space c s": "outline::Toggle",
      "space c shift-s": "editor::FindAllReferences",

      // ── Git (g) ──
      "space g g": ["task::Spawn", { "task_name": "lazygit", "reveal_target": "center" }],
      "space g shift-g": ["task::Spawn", { "task_name": "lazygit", "reveal_target": "center" }],
      "space g b": "git::Blame",
      "space g d": "git::Diff",
      "space g h s": "git::StageHunk",
      "space g h r": "git::Restore",
      "space g h shift-s": "git::StageFile",
      "space g h d": "editor::ToggleSelectedDiffHunks",
      "space g h b": "git::Blame",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      // ── Search (s) ──
      "space s s": "outline::Toggle",
      "space s shift-s": "project_symbols::Toggle",
      "space s g": "workspace::NewSearch",
      "space s shift-g": "workspace::NewSearch",
      "space s d": "diagnostics::Deploy",
      "space s shift-d": "diagnostics::Deploy",
      "space s r": "workspace::NewSearch",
      "space s shift-r": "file_finder::Toggle",
      "space s k": "zed::OpenKeymap",
      "space s c": "command_palette::Toggle",
      "space s shift-c": "command_palette::Toggle",
      "space s b": "vim::Search",
      "space s w": "buffer_search::Deploy",
      "space s shift-w": "pane::DeploySearch",
      "space s /": "workspace::NewSearch",

      // ── Diagnostics / Trouble (x) ──
      "space x x": "diagnostics::Deploy",
      "space x shift-x": "diagnostics::Deploy",
      "space x l": "diagnostics::Deploy",
      "space x shift-l": "diagnostics::Deploy",
      "space x q": "diagnostics::Deploy",
      "space x shift-q": "diagnostics::Deploy",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "] e": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",

      // ── UI Toggles (u) ──
      "space u b": "theme_selector::Toggle",
      "space u shift-c": "theme_selector::Toggle",
      "space u d": "diagnostics::Deploy",
      "space u l": "editor::ToggleRelativeLineNumbers",
      "space u shift-l": "editor::ToggleRelativeLineNumbers",
      "space u n": "notification_panel::ToggleFocus",

      // ── Debug (d) ──
      "space d b": "debugger::ToggleBreakpoint",
      "space d shift-b": "debugger::EditBreakpoint",
      "space d c": "debugger::Continue",
      "space d shift-c": "debugger::RunToCursor",
      "space d i": "debugger::StepInto",
      "space d l": "debugger::Start",
      "space d o": "debugger::StepOut",
      "space d shift-o": "debugger::StepOver",
      "space d shift-p": "debugger::Pause",
      "space d t": "debugger::Stop",
      "space d u": "debugger::OpenPanel",

      // ── Test (t) ──
      "space t r": ["editor::SpawnNearestTask", { "reveal": "no_focus" }],
      "space t t": ["task::Spawn", { "task_name": "test file" }],
      "space t shift-t": ["task::Spawn", { "task_name": "test all" }],
      "space t s": "workspace::ToggleBottomDock",

      // ── Quit (q) ──
      "space q q": "zed::Quit",
      "space q w": "workspace::CloseWindow",

      // ── Tabs (tab) ──
      "space tab tab": "workspace::NewFile",
      "space tab d": "pane::CloseActiveItem",
      "space tab ]": "pane::ActivateNextItem",
      "space tab [": "pane::ActivatePreviousItem",

      // ── Number jumps ──
      "space 1": ["pane::ActivateItem", 0],
      "space 2": ["pane::ActivateItem", 1],
      "space 3": ["pane::ActivateItem", 2],
      "space 4": ["pane::ActivateItem", 3],
      "space 5": ["pane::ActivateItem", 4],
      "space 6": ["pane::ActivateItem", 5],
      "space 7": ["pane::ActivateItem", 6],
      "space 8": ["pane::ActivateItem", 7],
      "space 9": ["pane::ActivateItem", 8],
      "space 0": "pane::ActivateLastItem",
    },
  },

  // ========= Editor (normal mode only) =========
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // Pane navigation
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      // Tab navigation
      "ctrl-shift-h": "pane::ActivatePreviousItem",
      "ctrl-shift-l": "pane::ActivateNextItem",
      // LSP / goto
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDeclaration",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g r": "editor::FindAllReferences",
      // gcc = comment line
      "g c c": "editor::ToggleComments",
      // Buffers
      "shift-q": "pane::CloseActiveItem",
      "ctrl-q": "pane::CloseActiveItem",
      "space b d": "pane::CloseActiveItem",
      "space b o": "pane::CloseOtherItems",
      // Save / misc
      "ctrl-s": "workspace::Save",
      "space space": "file_finder::Toggle",
      "space e": "workspace::ToggleLeftDock",
      "space b": "workspace::ToggleRightDock",
      "ctrl-a": "editor::SelectAll",
      "space .": "editor::ToggleCodeActions",
    },
  },

  // ========= Visual mode =========
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "Editor && vim_mode == visual && !VimWaiting && !menu",
    "bindings": {
      "g c": "editor::ToggleComments",
    },
  },

  // ========= Insert mode =========
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "j j": "vim::NormalBefore",
      "j k": "vim::NormalBefore",
    },
  },

  // ========= VimControl helpers =========
  {
    "context": "VimControl && !menu",
    "bindings": {
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-d z z"],
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-u z z"],
      "n": ["workspace::SendKeystrokes", "n z z z v"],
      "shift-n": ["workspace::SendKeystrokes", "shift-n z z z v"],
      "shift-g": ["workspace::SendKeystrokes", "shift-g z z"],
      "g r": "editor::FindAllReferences",
    },
  },

  // ========= Vim operators =========
  {
    "context": "vim_operator == d",
    "bindings": {
      "o": "editor::ExpandAllDiffHunks",
      "r": "git::Restore",
    },
  },
  {
    "context": "Editor && vim_operator == c",
    "bindings": {
      "c": "vim::CurrentLine",
      "r": "editor::Rename",
      "a": "editor::ToggleCodeActions",
    },
  },
  {
    "context": "vim_mode == normal || vim_mode == visual",
    "bindings": {
      "s": "vim::PushSneak",
      "S": "vim::PushSneakBackward",
    },
  },
  {
    "context": "vim_operator == a || vim_operator == i || vim_operator == cs",
    "bindings": {
      "b": "vim::AnyBrackets",
      "g": "editor::SelectAll",
      "shift-9": ["workspace::SendKeystrokes", "("],
      "shift-0": ["workspace::SendKeystrokes", ")"],
    },
  },

  // ========= Terminal =========
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },

  // ========= Dock navigation =========
  {
    "context": "Dock",
    "bindings": {
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w j": "workspace::ActivatePaneDown",
    },
  },

  // ========= Tasks =========
  {
    "context": "EmptyPane || SharedScreen || vim_mode == normal",
    "bindings": {
      "space r t": ["editor::SpawnNearestTask", { "reveal": "no_focus" }],
    },
  },

  // ========= Editor toggles =========
  {
    "context": "Editor",
    "bindings": {
      "ctrl-;": "editor::ToggleRelativeLineNumbers",
      "ctrl-shift-pagedown": "editor::ToggleLineNumbers",
    },
  },
]
