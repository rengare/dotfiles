{
  "features": {
    "edit_prediction_provider": "zed"
  },
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always"
  },
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "relative_line_numbers": true,
  "scrolloff": 8,
  "soft_wrap": "editor_width",
  "inlay_hints": { "enabled": true },
  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null
    }
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark Hard"
  },
  "terminal": {
    "shell": {
      "program": "/usr/bin/fish"
    },
    "copy_on_select": true
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-3-7-sonnet"
    },
    "version": "2"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "notification_panel": {
    "dock": "left"
  },
  "chat_panel": {
    "dock": "left"
  }
}
